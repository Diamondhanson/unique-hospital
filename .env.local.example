# ---------------------------------------------------------------------------
# Sanity — required for Studio + content fetching
# Copy this file to `.env.local` and fill in the values from sanity.io/manage.
# ---------------------------------------------------------------------------

# Public project id (find under Project settings → API)
NEXT_PUBLIC_SANITY_PROJECT_ID=

# Dataset name (defaults to "production" for new projects)
NEXT_PUBLIC_SANITY_DATASET=production

# Optional: pin a Sanity API version. Defaults to 2024-10-01 if unset.
# NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Optional: read token for fetching draft/preview content from server components.
# Generate under Project settings → API → Tokens with "Viewer" rights.
# SANITY_API_READ_TOKEN=

# ---------------------------------------------------------------------------
# Resend — required for the contact form
# Sign up at resend.com, create an API key, paste it here.
# ---------------------------------------------------------------------------

# API key from resend.com/api-keys
RESEND_API_KEY=

# Inbox that receives contact-form submissions
CONTACT_INBOX_EMAIL=

# Sender. Until you verify a custom domain in Resend, use
# "onboarding@resend.dev" — Resend will only deliver to the email tied to
# your account. Once a domain is verified, change to e.g.
# "Unique Hospital <noreply@yourdomain.com>".
RESEND_FROM_EMAIL=Unique Hospital <onboarding@resend.dev>
